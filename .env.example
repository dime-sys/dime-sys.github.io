# Copy this file to .env and fill in your values before starting the prod stack.
# NEVER commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=data_intake_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD

# ── Application ───────────────────────────────────────────────────────────────
# Public domain name (used for CORS). No trailing slash.
# Examples: miaplicacion.com  |  192.168.1.100
DOMAIN=yourdomain.com
